# =============================================================================
# .dockerignore — files excluded from the Docker build context
#
# Everything listed here is NOT sent to the Docker daemon when building.
# Use this to keep build contexts small, builds fast, and images free of
# host-only state (secrets, caches, virtualenvs, large datasets).
#
# Runtime data (data/, models/, mlruns/, reports/) is bind-mounted by
# docker-compose at runtime, so it is intentionally not baked into the image.
# =============================================================================

# --- Version control --------------------------------------------------------
.git/
.gitignore
.gitattributes

# --- Python bytecode / build artifacts --------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
build/
dist/
develop-eggs/
.eggs/
pip-wheel-metadata/

# --- Virtual environments (host-only; image installs into system site) ------
.venv/
venv/
env/
ENV/

# --- Test / lint / type-check caches ----------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.hypothesis/
.coverage
.coverage.*
htmlcov/
coverage.xml
nosetests.xml

# --- Editor / IDE / OS junk -------------------------------------------------
.vscode/
.idea/
.history/
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- Jupyter notebook outputs / checkpoints ---------------------------------
.ipynb_checkpoints/
**/.ipynb_checkpoints/
notebooks/*.ipynb

# --- DVC: keep tracked pointers + remote config, exclude cache + secrets ----
.dvc/cache/
.dvc/tmp/
.dvc/config.local

# --- Large datasets (bind-mounted via docker-compose) -----------------------
data/raw/
data/processed/

# --- Model artifacts / checkpoints (bind-mounted via docker-compose) --------
models/*.joblib
models/*.pkl
models/*.pt
models/*.pth
models/*.bin
models/*.safetensors
models/*.onnx
models/*.h5

# --- MLflow runs (bind-mounted via docker-compose) --------------------------
mlruns/
mlartifacts/

# --- Generated reports / predictions ----------------------------------------
reports/baseline_metrics.json
reports/predictions.csv
reports/figures/*.png
reports/figures/*.jpg
reports/figures/*.pdf

# --- Docs build output ------------------------------------------------------
docs/_build/
site/

# --- Logs -------------------------------------------------------------------
*.log
logs/

# --- Docker itself (avoid recursive context) --------------------------------
Dockerfile*
.dockerignore
docker-compose*.yaml
docker-compose*.yml
